{
  "expo": {
    "name": "Dengue Shield",
    "slug": "frontend",
    "sdkVersion": "55.0.0",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app_logo3.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.janani.dengueapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show dengue risk zones in your area.",
        "NSLocationAlwaysUsageDescription": "This app uses your location in the background to provide live dengue risk alerts even when the app is closed.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to provide live dengue risk alerts and show safety maps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/app_logo3.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.janani.dengueapp",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2uXEGUPYPTud3bnfD4pXPr-kY2fc4g8s"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/app_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow $(PRODUCT_NAME) to use your location in the background to provide live dengue risk alerts."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/app_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c4d491e-cd29-44d3-86e8-ee8a8a084669"
      }
    }
  }
}